{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.6",
    "body": [
        {
            "type": "TextBlock",
            "text": "Todoist Widget",
            "weight": "Bolder",
            "size": "Medium"
        },
        {
            "type": "TextBlock",
            "text": "${errorMessage}",
            "wrap": true,
            "color": "Attention",
            "size": "Small"
        }
    ],
    "actions": [
        {
            "type": "Action.Execute",
            "title": "Tekrar Dene",
            "verb": "refresh"
        },
        {
            "type": "Action.Execute",
            "title": "Token Degistir",
            "verb": "resetToken"
        }
    ]
}