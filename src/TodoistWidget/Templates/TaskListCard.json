{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.6",
    "verticalContentAlignment": "Top",
    "body": [
        {
            "type": "Container",
            "$when": "${overdueCount > 0}",
            "spacing": "None",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "Geciken  ${overdueCount}",
                    "weight": "Bolder",
                    "size": "Small",
                    "color": "Attention",
                    "spacing": "Small"
                },
                {
                    "type": "Container",
                    "$data": "${overdueTasks}",
                    "spacing": "Small",
                    "items": [
                        {
                            "type": "ColumnSet",
                            "spacing": "None",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "24px",
                                    "verticalContentAlignment": "Center",
                                    "items": [
                                        {
                                            "type": "ActionSet",
                                            "actions": [
                                                {
                                                    "type": "Action.Execute",
                                                    "title": "○",
                                                    "verb": "completeTask",
                                                    "data": { "taskId": "${id}" },
                                                    "style": "default"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "type": "Column",
                                    "width": "auto",
                                    "verticalContentAlignment": "Center",
                                    "spacing": "Small",
                                    "items": [
                                        {
                                            "type": "TextBlock",
                                            "text": "${priorityIcon}",
                                            "spacing": "None",
                                            "size": "Small"
                                        }
                                    ]
                                },
                                {
                                    "type": "Column",
                                    "width": "stretch",
                                    "verticalContentAlignment": "Center",
                                    "spacing": "Small",
                                    "items": [
                                        {
                                            "type": "TextBlock",
                                            "text": "${content}",
                                            "wrap": false,
                                            "size": "Small",
                                            "spacing": "None"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "Container",
            "$when": "${todayCount > 0}",
            "spacing": "Small",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "Bugun  ${todayCount}",
                    "weight": "Bolder",
                    "size": "Small",
                    "spacing": "Small"
                },
                {
                    "type": "Container",
                    "$data": "${todayTasks}",
                    "spacing": "Small",
                    "items": [
                        {
                            "type": "ColumnSet",
                            "spacing": "None",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "24px",
                                    "verticalContentAlignment": "Center",
                                    "items": [
                                        {
                                            "type": "ActionSet",
                                            "actions": [
                                                {
                                                    "type": "Action.Execute",
                                                    "title": "○",
                                                    "verb": "completeTask",
                                                    "data": { "taskId": "${id}" },
                                                    "style": "default"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "type": "Column",
                                    "width": "auto",
                                    "verticalContentAlignment": "Center",
                                    "spacing": "Small",
                                    "items": [
                                        {
                                            "type": "TextBlock",
                                            "text": "${priorityIcon}",
                                            "spacing": "None",
                                            "size": "Small"
                                        }
                                    ]
                                },
                                {
                                    "type": "Column",
                                    "width": "stretch",
                                    "verticalContentAlignment": "Center",
                                    "spacing": "Small",
                                    "items": [
                                        {
                                            "type": "TextBlock",
                                            "text": "${content}",
                                            "wrap": false,
                                            "size": "Small",
                                            "spacing": "None"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "TextBlock",
            "$when": "${offlineNotice != ''}",
            "text": "${offlineNotice}",
            "size": "Small",
            "isSubtle": true,
            "color": "Warning",
            "spacing": "Small"
        }
    ],
    "actions": [
        {
            "type": "Action.Execute",
            "title": "Yenile",
            "verb": "refresh"
        }
    ]
}
